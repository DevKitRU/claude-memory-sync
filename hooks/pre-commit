#!/usr/bin/env bash
# Claude Memory Sync — pre-commit hook для детекции секретов.
#
# Установка:
#   cp <claude-memory-sync>/hooks/pre-commit <твой-memory-репо>/.git/hooks/
#   chmod +x <твой-memory-репо>/.git/hooks/pre-commit
#
# Проверяет staged изменения на типичные паттерны API-ключей, токенов,
# приватных ключей. Отклоняет коммит если нашёл — приходится убирать
# секрет или, в исключительных случаях, коммитить с --no-verify.
#
# Чтобы обновить паттерны — правь массив PATTERNS ниже.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Список паттернов. Формат: "regex|описание"
# Regex — ERE (extended). Без лишних escape'ов.
PATTERNS=(
    # Anthropic
    "sk-ant-[a-zA-Z0-9_-]{20,}|Anthropic API key"
    # OpenAI
    "sk-(proj-)?[a-zA-Z0-9_-]{20,}|OpenAI API key"
    # GitHub tokens
    "ghp_[a-zA-Z0-9]{30,}|GitHub personal access token"
    "ghs_[a-zA-Z0-9]{30,}|GitHub server-to-server token"
    "github_pat_[a-zA-Z0-9_]{80,}|GitHub fine-grained PAT"
    "gho_[a-zA-Z0-9]{30,}|GitHub OAuth token"
    # Slack
    "xox[bpoas]-[0-9]+-[0-9]+-[0-9]+-[a-f0-9]{32}|Slack token"
    # Telegram
    "[0-9]{8,10}:[A-Za-z0-9_-]{35}|Telegram bot token"
    # AWS
    "AKIA[0-9A-Z]{16}|AWS access key"
    "aws_secret_access_key[[:space:]]*=[[:space:]]*[A-Za-z0-9/+=]{40}|AWS secret"
    # Google
    "AIza[0-9A-Za-z_-]{35}|Google API key"
    # Stripe
    "sk_live_[a-zA-Z0-9]{24,}|Stripe live key"
    "rk_live_[a-zA-Z0-9]{24,}|Stripe restricted key"
    # JWT (consumer of Bearer-headers often)
    "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}|JWT token"
    # Generic Bearer/Authorization
    "[Bb]earer[[:space:]]+[A-Za-z0-9._-]{30,}|Bearer token"
    # Generic long API_KEY / TOKEN assignments
    "(API_?KEY|SECRET|TOKEN|PASSWORD)[[:space:]]*[:=][[:space:]]*[\"']?[A-Za-z0-9_/+=-]{30,}[\"']?|Generic secret assignment"
    # SSH / PGP private keys
    "-----BEGIN (RSA |OPENSSH |EC |DSA |PGP )?PRIVATE KEY-----|Private key header"
    # OAuth2
    "ya29\\.[a-zA-Z0-9_-]{30,}|Google OAuth2 token"
)

# Allowlist — строки которые содержат SECRETS_OK_PLACEHOLDER считаем намеренными примерами
ALLOWLIST_MARKER="SECRETS_OK_PLACEHOLDER"

# Получаем список staged файлов
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

FOUND=0
FINDINGS=""

while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    [[ ! -f "$file" ]] && continue

    # Пропускаем по расширению очевидные бинарники / lock-файлы
    case "$file" in
        *.lock|*.png|*.jpg|*.jpeg|*.gif|*.pdf|*.zip|*.tar|*.gz|*.bin|*.woff|*.woff2|*.ttf) continue;;
    esac

    # Берём только staged diff (что реально добавляется). git сам помечает бинарный diff
    # как "Binary files ... differ" — это не попадёт под `^+` и естественно отфильтруется.
    DIFF=$(git diff --cached -U0 -- "$file" 2>/dev/null | grep '^+' | grep -v '^+++' || true)
    [[ -z "$DIFF" ]] && continue
    # Дополнительная страховка: если вместо diff пришёл маркер "Binary files"
    if echo "$DIFF" | head -1 | grep -q '^Binary files'; then continue; fi

    # Отслеживаем уже найденные строки чтобы не алертить одну и ту же строку
    # двумя overlapping regex'ами (например Anthropic-ключ матчится и Anthropic, и OpenAI паттернами)
    SEEN_LINES=""

    for pattern in "${PATTERNS[@]}"; do
        regex="${pattern%%|*}"
        desc="${pattern##*|}"
        matches=$(echo "$DIFF" | grep -nE -- "$regex" 2>/dev/null | grep -v -- "$ALLOWLIST_MARKER" 2>/dev/null || true)
        [[ -z "$matches" ]] && continue

        # Убираем строки которые уже сматчили более ранним (более специфичным) паттерном
        while IFS= read -r mline; do
            lineno="${mline%%:*}"
            if echo "$SEEN_LINES" | grep -qxF "$lineno"; then
                continue
            fi
            SEEN_LINES+="$lineno"$'\n'
            if [[ -z "${FINDINGS_BY_PATTERN:-}" ]]; then FINDINGS_BY_PATTERN=""; fi
            FINDINGS_BY_PATTERN+="${RED}!${NC} $file:$lineno → $desc\n"
            masked=$(echo "$mline" | sed -E "s/([A-Za-z0-9]{6})[A-Za-z0-9_/.+=-]{10,}/\1********/g")
            FINDINGS_BY_PATTERN+="    $masked\n"
            FOUND=1
        done <<< "$matches"
    done

    if [[ -n "${FINDINGS_BY_PATTERN:-}" ]]; then
        FINDINGS+="$FINDINGS_BY_PATTERN"
        FINDINGS_BY_PATTERN=""
    fi
done <<< "$STAGED_FILES"

if [[ $FOUND -eq 1 ]]; then
    echo -e "${RED}========================================${NC}"
    echo -e "${RED}  PRE-COMMIT: найдены возможные секреты${NC}"
    echo -e "${RED}========================================${NC}"
    echo ""
    echo -e "$FINDINGS"
    echo ""
    echo -e "${YELLOW}Что делать:${NC}"
    echo "  1. Убери секрет из файла. Храни ключи в ~/.claude/secrets/api-keys.env"
    echo "     или в secret manager (1Password CLI, Keychain, Bitwarden)."
    echo "  2. Если это ложное срабатывание (пример в доке, не реальный ключ):"
    echo "     добавь маркер '# $ALLOWLIST_MARKER' в соседнюю строку,"
    echo "     либо закоммить с: git commit --no-verify"
    echo "  3. Если ключ уже уехал в предыдущий коммит — **отзови и ротируй**"
    echo "     (git filter-branch не спасёт от кеша GitHub)."
    echo ""
    exit 1
fi

exit 0
